{
    "compilerOptions": {
        "outDir": "./dist/",
        "noImplicitAny": true,
        "module": "ESNext",
        "target": "es5",
        "baseUrl": ".",
        "paths": {
            "*": ["./src/*"]
        },
        "jsx": "react-jsx",
        "allowJs": true,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "esModuleInterop": true
    },
    "ts-node": {
        "compilerOptions": {
            "module": "CommonJS"
        }
    },
    "exclude": ["node_modules", "build"],
    "include": [
        "./config/jest/setupTests.ts",
        "src",
        "src/global.d.ts",
        "./src/**/*.ts",
        "./src/**/*.tsx"
    ]
}
